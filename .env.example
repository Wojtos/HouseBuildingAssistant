# =============================================================================
# Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# For E2E tests, copy to .ai/.env.test

# =============================================================================
# Supabase Configuration
# =============================================================================
# Your Supabase project URL (e.g., https://xxxx.supabase.co or http://localhost:54321)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Supabase anonymous key for client-side access
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key

# Supabase service role key for server-side operations (KEEP SECRET)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# Backend Configuration
# =============================================================================
# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# OpenRouter AI Configuration
# =============================================================================
# OpenRouter API key for AI model access (KEEP SECRET)
OPENROUTER_API_KEY=your-openrouter-api-key

# OpenRouter base URL (optional, defaults to https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# Development Settings
# =============================================================================
# Enable mock authentication for development (true/false)
MOCK_AUTH=false

# CORS allowed origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:4001,http://localhost:3000

# =============================================================================
# E2E Testing Configuration
# =============================================================================
# Test user credentials for E2E tests
E2E_USERNAME=test@example.com
E2E_PASSWORD=your-test-password

# Base URL for E2E tests
BASE_URL=http://localhost:4001
