FROM node:20-slim

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies (using legacy-peer-deps for React 19 compatibility)
RUN npm install --legacy-peer-deps

# Create non-root user (check if user/UID exists first)
RUN (id -u 1000 >/dev/null 2>&1 || useradd -m -u 1000 appuser) && chown -R 1000:1000 /app
USER 1000

# Expose port
EXPOSE 4001

# Default command (will be overridden in docker-compose for dev)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "4001"]

