---
/**
 * Sign Up Page
 * 
 * Public page for new user registration.
 * Uses AuthLayout and mounts AuthForm React island.
 * Redirects to /projects if user is already authenticated.
 */
export const prerender = false;

import AuthLayout from '../layouts/AuthLayout.astro';
import { AuthForm } from '../components/AuthForm';
import { createSupabaseServerInstance } from '../db/supabase.server';

// Check if user is already authenticated
const supabase = createSupabaseServerInstance({
  cookies: Astro.cookies,
  headers: Astro.request.headers,
});

const { data: { user } } = await supabase.auth.getUser();

// If authenticated, redirect to projects or the requested redirect target
if (user) {
  const redirectTo = Astro.url.searchParams.get('redirectTo');
  // Validate redirect target is safe (relative path, no protocol)
  const safeRedirect = redirectTo && redirectTo.startsWith('/') && !redirectTo.includes('//')
    ? redirectTo
    : '/projects';
  return Astro.redirect(safeRedirect, 302);
}
---

<AuthLayout 
  title="Create Account - House Building Assistant"
  description="Create a new House Building Assistant account"
>
  <AuthForm client:load mode="signup" />
</AuthLayout>
