---
/**
 * Account Settings Page - Protected Route
 *
 * Route: /settings/account
 * Renders the AccountSettingsView component for managing user profile preferences.
 * 
 * Access to this page is protected by server-side middleware.
 * Unauthenticated users are redirected to /login before this page renders.
 */

import '../../styles/global.css';
import { AccountSettingsView } from '../../components/AccountSettingsView';
import { LogoutButton } from '../../components/LogoutButton';

// User is guaranteed to exist here - middleware redirects unauthenticated users
const { user } = Astro.locals;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Manage your account settings and preferences" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google Fonts for Google-like appearance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>Account Settings - House Building Assistant</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <!-- Simple header -->
    <header class="border-b border-gray-200 bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <div class="flex items-center gap-4">
            <a href="/projects" class="text-xl font-semibold text-gray-900">
              House Building Assistant
            </a>
          </div>
          <LogoutButton client:load className="text-sm font-medium text-gray-600 hover:text-gray-900" />
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main>
      <AccountSettingsView client:load />
    </main>
  </body>
</html>
