---
/**
 * Projects List Page - Protected Route
 * 
 * Route: /projects
 * First post-login destination. Lists user's projects with filters and pagination.
 * 
 * Access to this page is protected by server-side middleware.
 * Unauthenticated users are redirected to /login before this page renders.
 */
import '../../styles/global.css';
import { ProjectsListView } from '../../components/ProjectsListView';
import { LogoutButton } from '../../components/LogoutButton';

// User is guaranteed to exist here - middleware redirects unauthenticated users
const { user } = Astro.locals;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Manage your building projects with House Building Assistant" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google Fonts for Google-like appearance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>My Projects - House Building Assistant</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <ProjectsListView client:load />
  </body>
</html>
