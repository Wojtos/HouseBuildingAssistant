---
/**
 * Project Settings Page - Protected Route
 *
 * Route: /projects/:projectId/settings
 * Renders the ProjectSettingsView component for project configuration.
 * 
 * Access to this page is protected by server-side middleware.
 * Unauthenticated users are redirected to /login before this page renders.
 */

import ProjectLayout from '../../../layouts/ProjectLayout.astro';
import { ProjectSettingsView } from '../../../components/ProjectSettingsView';

// User is guaranteed to exist here - middleware redirects unauthenticated users
const { user } = Astro.locals;

const { projectId } = Astro.params;

// Validate projectId parameter
if (!projectId) {
  return Astro.redirect('/projects');
}
---

<ProjectLayout
  title="Project Settings - House Building Assistant"
  description="Manage project settings and configuration"
  projectId={projectId}
  activeNavKey="settings"
>
  <ProjectSettingsView client:load projectId={projectId} />
</ProjectLayout>
