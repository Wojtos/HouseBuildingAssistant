---
/**
 * Project Files Page - Protected Route
 *
 * Route: /projects/:projectId/files
 * Renders the ProjectFilesView component for document management.
 * 
 * Access to this page is protected by server-side middleware.
 * Unauthenticated users are redirected to /login before this page renders.
 */

import ProjectLayout from '../../../../layouts/ProjectLayout.astro';
import { ProjectFilesView } from '../../../../components/ProjectFilesView';

// User is guaranteed to exist here - middleware redirects unauthenticated users
const { user } = Astro.locals;

const { projectId } = Astro.params;

// Validate projectId parameter
if (!projectId) {
  return Astro.redirect('/projects');
}
---

<ProjectLayout
  title="Project Files - House Building Assistant"
  description="Upload and manage project documents"
  projectId={projectId}
  activeNavKey="files"
>
  <ProjectFilesView client:load projectId={projectId} />
</ProjectLayout>
