---
/**
 * Project Facts Page - Protected Route
 *
 * Route: /projects/:projectId/facts
 * Renders the ProjectFactsView component for viewing project memory.
 * 
 * Access to this page is protected by server-side middleware.
 * Unauthenticated users are redirected to /login before this page renders.
 */

import ProjectLayout from '../../../layouts/ProjectLayout.astro';
import { ProjectFactsView } from '../../../components/ProjectFactsView';

// User is guaranteed to exist here - middleware redirects unauthenticated users
const { user } = Astro.locals;

const { projectId } = Astro.params;

// Validate projectId parameter
if (!projectId) {
  return Astro.redirect('/projects');
}
---

<ProjectLayout
  title="Project Facts - House Building Assistant"
  description="View project knowledge and facts"
  projectId={projectId}
  activeNavKey="facts"
>
  <ProjectFactsView client:load projectId={projectId} />
</ProjectLayout>
