---
/**
 * ProjectLayout
 * 
 * HTML shell for project-scoped pages (chat, files, facts, settings).
 * Provides consistent structure and mounts the ProjectShell React component.
 */
import '../styles/global.css';
import { ProjectShell } from '../components/ProjectShell';
import type { ProjectNavKey } from '../types/viewModels';

interface Props {
  title: string;
  description?: string;
  projectId: string;
  activeNavKey: ProjectNavKey;
}

const {
  title,
  description = 'House Building Assistant - Your AI-powered construction companion',
  projectId,
  activeNavKey,
} = Astro.props;

// Basic UUID validation
const UUID_REGEX = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
const isValidUUID = UUID_REGEX.test(projectId);

// If projectId is invalid, redirect to 404
if (!isValidUUID) {
  return Astro.redirect('/404');
}

// User is guaranteed to exist here - middleware redirects unauthenticated users
const { user } = Astro.locals;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google Fonts for Google-like appearance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-50">
    <ProjectShell
      client:load
      projectId={projectId}
      activeNavKey={activeNavKey}
    >
      <slot />
    </ProjectShell>
  </body>
</html>
